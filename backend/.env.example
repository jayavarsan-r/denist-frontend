# ─── Runtime ───────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ─── Supabase ──────────────────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your_service_role_key_here
SUPABASE_ANON_KEY=your_anon_key_here

# ─── Auth ──────────────────────────────────────────────────────────────────
JWT_SECRET=generate_a_64_char_random_string_here

# ─── AI providers ──────────────────────────────────────────────────────────
# Sarvam = speech-to-text. Gemini = transcript structuring.
# In production both MUST be set — the server fails fast at startup if missing.
# In development, leaving these blank activates the mock provider.
SARVAM_API_KEY=your_sarvam_api_key_here
# Gemini supports KEY ROTATION to stay under free-tier per-minute limits. Provide as
# many keys as you have — requests round-robin across them and skip any key that is
# rate-limited (429/403). Any ONE of these forms works (they're all merged):
#   GEMINI_API_KEYS=key1,key2,key3            (comma-separated — easiest for many keys)
#   GEMINI_API_KEY_1=key1                      (numbered, up to _12)
#   GEMINI_API_KEY_2=key2
#   GEMINI_API_KEY=key                          (legacy single key — still supported)
GEMINI_API_KEY=your_gemini_api_key_here
# GEMINI_API_KEYS=key1,key2,key3

# ─── OTP delivery provider ─────────────────────────────────────────────────
# stub  = logs the code instead of sending (dev / pre-launch clinic testing)
# msg91 = real SMS via MSG91 — going live is JUST this config change, no code change
OTP_PROVIDER=stub
MSG91_AUTH_KEY=
MSG91_TEMPLATE_ID=

# Dev shortcuts (NEVER set in production):
# USE_DEV_OTP=true pins every phone to DEV_OTP so no SMS is needed.
USE_DEV_OTP=true
DEV_OTP=123456
# Optional fixed code for non-pinned phones (leave empty for random):
DEV_OTP_OTHER=
# Optional demo account phone that always verifies with DEV_OTP:
DEMO_PHONE=

# ─── Patient notifications (WhatsApp/SMS) ──────────────────────────────────
NOTIFICATION_PROVIDER=stub

# ─── WhatsApp BSP (lab tracker + patient reminders + EOD) ──────────────────
# stub    = logs to console with fake message ids (default — whole engine runs)
# aisensy = real AiSensy API (BSP account + approved templates) — has a platform fee
# meta    = direct Meta Cloud API (Graph API) — no BSP fee (recommended for prod)
WHATSAPP_PROVIDER=stub
AISENSY_API_KEY=
AISENSY_CAMPAIGN_NAME_PREFIX=dentai_
# Meta hub challenge token (your choice) — also used by aisensy + meta.
WHATSAPP_WEBHOOK_VERIFY_TOKEN=dentai_webhook_verify_2026
# Webhook signature secret. For WHATSAPP_PROVIDER=meta this is your Meta App Secret
# (App Dashboard → Settings → Basic). For aisensy it is the BSP signing secret.
WHATSAPP_WEBHOOK_SECRET=

# ─── Meta Cloud API (WHATSAPP_PROVIDER=meta) ───────────────────────────────
# META_WHATSAPP_TOKEN     = permanent system-user token from Meta Business Manager
# META_PHONE_NUMBER_ID    = default sending number id (single-clinic / dev). Per-clinic
#                           numbers live in clinics.meta_phone_number_id (migration 017).
# META_GRAPH_VERSION      = optional Graph API version override (default v18.0)
META_WHATSAPP_TOKEN=
META_PHONE_NUMBER_ID=
# META_GRAPH_VERSION=v18.0
#
# One-time Meta setup:
#  1. business.facebook.com → create Business Manager + a WhatsApp Business Account (WABA)
#  2. Business Settings → System Users → Add → grant full WABA permissions
#  3. Generate a PERMANENT token for that system user → META_WHATSAPP_TOKEN
#  4. Add + verify a phone number on the WABA → copy its phone_number_id → META_PHONE_NUMBER_ID
#  5. WhatsApp Manager → Configuration → webhook URL: https://<backend>/api/webhooks/whatsapp
#     Verify token = WHATSAPP_WEBHOOK_VERIFY_TOKEN ; subscribe to: messages, message_status_updates
#  6. Set WHATSAPP_WEBHOOK_SECRET = your Meta App Secret
#  7. Set WHATSAPP_PROVIDER=meta and flip the FEATURE_WHATSAPP_* flags when templates are approved
#  Per-clinic numbers: add number to WABA → phone_number_id → clinics.meta_phone_number_id

# Feature flags: messages are built/queued/logged either way, but only SENT when
# true. Flip after the BSP is live and templates approved — no code change.
FEATURE_WHATSAPP_PATIENT_REMINDERS=false
FEATURE_WHATSAPP_LAB_OUTBOUND=false

# ─── Job queue (pg-boss — async voice pipeline) ────────────────────────────
# Direct Postgres connection string for the SAME Supabase project (Settings →
# Database → Connection string). pg-boss creates its own `pgboss` schema.
# Without it the server still boots but voice processing answers 503.
DATABASE_URL=
PGBOSS_SCHEMA=pgboss

# ─── Tuning ────────────────────────────────────────────────────────────────
# Requests per 15 min per IP (defaults: 1000 prod / unlimited dev)
RATE_LIMIT_MAX=
