# ─── Runtime ───────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ─── Supabase ──────────────────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your_service_role_key_here
SUPABASE_ANON_KEY=your_anon_key_here

# ─── Auth ──────────────────────────────────────────────────────────────────
JWT_SECRET=generate_a_64_char_random_string_here

# ─── AI providers ──────────────────────────────────────────────────────────
# Sarvam = speech-to-text. Gemini = transcript structuring.
# In production both MUST be set — the server fails fast at startup if missing.
# In development, leaving these blank activates the mock provider.
SARVAM_API_KEY=your_sarvam_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here

# ─── OTP (development / clinic-testing mock) ───────────────────────────────
# NOTE: OTP is intentionally mocked for clinic testing. No SMS is sent.
# Every phone verifies with the fixed code below. Do NOT wire a real provider here.
DEMO_PHONE=
DEV_OTP=123456
DEV_OTP_OTHER=123456
