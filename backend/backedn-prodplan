-- Atomic pending_amount recalculation (called by transaction.service.js)
CREATE OR REPLACE FUNCTION recalc_pending_amount(plan_id UUID)
RETURNS TABLE(collected_amount NUMERIC, pending_amount NUMERIC) AS $$
BEGIN
  UPDATE treatment_plans
  SET pending_amount = GREATEST(0, estimated_cost - collected_amount)
  WHERE id = plan_id
  RETURNING collected_amount, pending_amount;
END;
$$ LANGUAGE plpgsql;

