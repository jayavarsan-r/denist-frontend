Response Envelope (All Endpoints)
// Success
{ success: true, data: <payload> }

// Success + pagination
{ success: true, data: [...], meta: { page, limit, total } }

// Error
{ success: false, error: { code: 'UNAUTHORIZED', message: '...', details: {} } }

// AI endpoint (always present)
{ success: true, data: { structured: {...} }, ai: { status: 'success'|'fallback'|'error', provider: 'gemini'|'sarvam', warning: null } }
utils/response.js exports ok(res, data, meta?), fail(res, status, code, message, details?). utils/errors.js exports AppError(code, message, status) for throw-able errors. errorHandler.js catches AppError and unknown errors, always responds with the error envelope.

